    // Resets everything to the start of the app
    public void ResetCards()
    {
        StatisticsManager.RefreshStatistics();
        CardManager.RefreshCards();
        GameState.RefreshGameState(CardManager.MainDeck, CardManager.ExtraDeck);
        supportedCards.RefreshUpdate();
    }
